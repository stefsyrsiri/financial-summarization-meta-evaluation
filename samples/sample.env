# Possible values are English, Spanish, Greek
LANGUAGE=English

# SUMMARY_VER: Version identifier for summaries taken from gold_summaries
# English: _1
# Greek: _2
# Spanish: _GS1
SUMMARY_VER=_1

# FILE_EXTENSION: File extension for summary files
FILE_EXTENSION=.txt

# Summaries
GOLD_SUMMARIES_DIR=data/${LANGUAGE}/training/gold_summaries/
CANDIDATE_SUMMARIES_DIR=data/${LANGUAGE}/training/candidate_summaries_trunc/
ANNUAL_REPORTS_DIR=data/${LANGUAGE}/training/annual_reports/
EVALUATION_CONFIG_PATH=src/conf/config.yaml
RESULTS_PATH=results/evaluation/${LANGUAGE}

# BATCH_SIZE: Batch size for evaluation with GPU-bound metrics
BATCH_SIZE=

# Sampling
N_SAMPLES=
SAMPLED_DOCS_PATH=results/sampling/${LANGUAGE}_sampled_docs.txt
SEEDS_PATH=results/sampling/${LANGUAGE}_seeds.json

# EDA: Merged datasets and statistics
# Path to save the merged dataset
DATASET_PATH=results/eda/df.parquet
# Path to save the text statistics
STATISTICS_PATH=results/eda/text_stats.parquet
